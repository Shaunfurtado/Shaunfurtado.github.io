---
import '../styles/global.css';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const topPosts = allPosts
  .filter((post) => !post.data.draft)
  .sort(
    (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
  );

const formatDate = (value: Date) =>
  value.toLocaleDateString('en-GB', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
  });
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Shaun Furtado</title>
    <meta
      name="description"
      content="Personal portfolio of Shaun Furtado focused on systems architecture, AI agents, and deterministic infrastructure."
    />
    <meta property="og:title" content="Shaun Furtado" />
    <meta
      property="og:description"
      content="Portfolio of systems architecture, intelligence, and deterministic engineering."
    />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:type" content="website" />

    <style>
      :global(body) {
        background-attachment: fixed;
      }
    </style>
  </head>
  <body class="antialiased min-h-screen flex flex-col justify-between selection:bg-ink selection:text-void">
    <header class="p-6 md:p-12 flex justify-between items-start font-mono text-[10px] md:text-xs text-muted uppercase tracking-widest fade-in-up">
      <div></div>
      <div class="text-right">
        <span>Loc: India</span><br />
        <span id="utc-time">Time: --:--:--</span>
      </div>
    </header>

    <main class="flex-grow flex flex-col justify-center px-6 md:px-12 max-w-7xl mx-auto w-full py-20">
      <div class="mb-24 fade-in-up delay-1">
        <h1 class="text-6xl md:text-8xl lg:text-9xl font-black tracking-tighter leading-none mb-6 text-ink">
          Shaun<br />Furtado.
        </h1>
        <p class="font-mono text-sm md:text-base text-muted uppercase tracking-widest">
          Systems Architect // Engineer
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-6 mb-32 fade-in-up delay-2">
        <div class="md:col-span-4 font-mono text-xs uppercase tracking-widest text-muted pt-2">
          [ Philosophy ]
        </div>
        <div class="md:col-span-8 lg:col-span-6">
          <p class="text-xl md:text-3xl font-light leading-relaxed text-ink/90">
            The technology stack is transient; the architectural principles are
            permanent. I engineer deterministic systems in stochastic environments,
            focusing on low-latency infrastructure, applied intelligence, and
            mathematical precision. I build things to last.
          </p>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-6 fade-in-up delay-3">
        <div class="md:col-span-4 font-mono text-xs uppercase tracking-widest text-muted pt-2">
          [ Domains ]
        </div>
        <div class="md:col-span-8 lg:col-span-8">
          <ul class="space-y-8 md:space-y-12">
            <li class="border-t border-surface pt-6">
              <h2 class="text-2xl md:text-4xl font-medium tracking-tight mb-3">
                Applied Intelligence & Agentic Systems
              </h2>
              <p class="text-muted md:text-lg max-w-2xl font-light">
                Designing multi-agent topologies and real-time inference engines.
                Moving beyond wrappers to build deep, context-aware architectures that
                operate autonomously.
              </p>
            </li>
            <li class="border-t border-surface pt-6">
              <h2 class="text-2xl md:text-4xl font-medium tracking-tight mb-3">
                High-Throughput Infrastructure
              </h2>
              <p class="text-muted md:text-lg max-w-2xl font-light">
                Architecting native, low-resource pipelines capable of processing
                extreme data volatility and real-time state synchronization with zero
                tolerance for failure.
              </p>
            </li>
            <li class="border-t border-surface pt-6">
              <h2 class="text-2xl md:text-4xl font-medium tracking-tight mb-3">
                Deterministic Architecture
              </h2>
              <p class="text-muted md:text-lg max-w-2xl font-light">
                Prioritizing sound mathematical models, strict privacy protocols, and
                uncompromising system stability over developmental trends.
              </p>
            </li>
          </ul>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-6 mt-32 fade-in-up delay-4">
        <div class="md:col-span-4 font-mono text-xs uppercase tracking-widest text-muted pt-2">
          [ Log ]
        </div>
        <div class="md:col-span-8 lg:col-span-8">
          <ul class="space-y-2">
            {topPosts.slice(0, 3).map((post) => (
              <li class="group flex flex-col md:flex-row md:items-baseline gap-2 md:gap-8 border-t border-surface pt-6 pb-4">
                <span class="font-mono text-xs text-muted w-28 shrink-0">
                  {formatDate(post.data.pubDate)}
                </span>
                <a
                  href={`/blog/${post.id}/`}
                  class="text-xl md:text-2xl font-light text-ink/80 group-hover:text-white transition-colors duration-300"
                >
                  {post.data.title}
                </a>
              </li>
            ))}
          </ul>
          <div class="mt-12">
            <a
              href="/blog/"
              class="hover-line font-mono text-xs uppercase tracking-widest text-muted hover:text-ink transition-colors"
            >
              -> Go to the Blog
            </a>
          </div>
        </div>
      </div>
    </main>

    <footer class="px-6 md:px-12 py-12 border-t border-surface flex flex-col md:flex-row justify-between items-end gap-8 fade-in-up delay-4">
      <div class="flex flex-col gap-4 font-mono text-sm uppercase tracking-widest">
        <div class="text-xs text-muted mb-2">[ Destinations ]</div>
        <a href="/blog/" class="hover-line text-ink w-max">
          -> The Archive
        </a>
        <a
          href="https://github.com/Shaunfurtado"
          target="_blank"
          rel="noopener noreferrer"
          class="hover-line text-ink w-max"
        >
          -> GitHub
        </a>
        <a
          href="https://linkedin.com/in/shaun-furtado-16579722b/"
          target="_blank"
          rel="noopener noreferrer"
          class="hover-line text-ink w-max"
        >
          -> LinkedIn
        </a>
        <a href="mailto:shaunf1801@gmail.com" class="hover-line text-ink w-max">
          -> Email
        </a>
      </div>

      <div class="text-right"></div>
    </footer>

    <script>
      function updateTime() {
        const timeElement = document.getElementById('utc-time');
        const now = new Date();
        const hours = String(now.getUTCHours()).padStart(2, '0');
        const minutes = String(now.getUTCMinutes()).padStart(2, '0');
        const seconds = String(now.getUTCSeconds()).padStart(2, '0');
        timeElement.textContent = `Time: ${hours}:${minutes}:${seconds} UTC`;
      }

      setInterval(updateTime, 1000);
      updateTime();
    </script>
  </body>
</html>

---
import '../../styles/global.css';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const formatDate = (value: Date) =>
  value.toLocaleDateString('en-GB', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
  });
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Blog | Shaun Furtado</title>
    <meta
      name="description"
      content="Notes and essays on systems architecture, deterministic engineering, AI infrastructures, and software craft."
    />
    <meta property="og:title" content="Blog | Shaun Furtado" />
    <meta
      property="og:description"
      content="Notes and essays on systems architecture, deterministic engineering, AI infrastructures, and software craft."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta name="robots" content="index, follow" />

    <style>
      :global(body) {
        font-family: var(--font-sans);
      }
    </style>
  </head>
  <body class="antialiased">
    <main class="max-w-4xl mx-auto px-6 py-16 space-y-10">
      <p class="font-mono text-xs uppercase tracking-widest text-zinc-400">[ Archive ]</p>
      <h1 class="text-4xl md:text-6xl font-black tracking-tight text-zinc-100">
        Blog
      </h1>
      <p class="text-zinc-300 text-lg md:text-xl max-w-2xl">
        Practical notes from current work and experiments across architecture,
        inference systems, and infrastructure.
      </p>

      <div class="space-y-6">
        {posts.map((post) => (
          <article class="border-t border-zinc-800 pt-6">
            <p class="font-mono text-xs text-zinc-500 mb-2">
              {formatDate(post.data.pubDate)}
            </p>
            <h2 class="text-2xl md:text-3xl text-zinc-100 mb-2">
              <a href={`/blog/${post.id}/`} class="hover:underline">
                {post.data.title}
              </a>
            </h2>
            <p class="text-zinc-300 max-w-2xl">{post.data.description}</p>
          </article>
        ))}

        {posts.length === 0 && (
          <p class="text-zinc-400">No blog posts are published yet.</p>
        )}
      </div>

      <p class="pt-6">
        <a href="/" class="text-sm font-mono uppercase tracking-widest text-zinc-400">
          -> Back home
        </a>
      </p>
    </main>
  </body>
</html>

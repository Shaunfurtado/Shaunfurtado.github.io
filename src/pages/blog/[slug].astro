---
import '../../styles/global.css';
import { CollectionEntry, getCollection, render } from 'astro:content';

type Props = {
  post: CollectionEntry<'blog'>;
};

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts
    .filter((post) => !post.data.draft)
    .map((post) => ({
      params: { slug: post.id },
      props: { post },
    }));
}

const { post } = Astro.props as Props;
const { Content } = await render(post);

const formatDate = (value: Date) =>
  value.toLocaleDateString('en-GB', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{post.data.title} | Shaun Furtado</title>
    <meta name="description" content={post.data.description} />
    <meta property="og:title" content={post.data.title} />
    <meta property="og:description" content={post.data.description} />
    <meta
      property="article:published_time"
      content={post.data.pubDate.toISOString()}
    />
    <meta property="og:url" content={`https://shaunfurtado.is-a.dev/blog/${post.id}/`} />
    <meta property="og:type" content="article" />
    <meta name="robots" content="index, follow" />

    <script is:inline>
      const savedTheme = (() => {
        try {
          return localStorage.getItem('theme');
        } catch {
          return null;
        }
      })();
      const systemTheme = window.matchMedia('(prefers-color-scheme: light)').matches
        ? 'light'
        : 'dark';
      document.documentElement.dataset.theme = savedTheme || systemTheme;
    </script>
  </head>
  <body class="app-shell antialiased">
    <main class="max-w-4xl mx-auto px-6 py-16 space-y-6">
      <p class="kicker">
        {formatDate(post.data.pubDate)}
      </p>
      <h1 class="text-4xl md:text-5xl font-black leading-tight max-w-3xl" style="letter-spacing: 0; color: var(--ink);">
        {post.data.title}
      </h1>
      <article class="blog-post prose max-w-none prose-headings:font-medium prose-a:no-underline hover:prose-a:underline" style="--tw-prose-body: var(--ink-soft); --tw-prose-bold: var(--ink); --tw-prose-code: var(--ink); --tw-prose-quotes: var(--ink); --tw-prose-counters: var(--muted); --tw-prose-bullets: var(--muted); --tw-prose-hr: var(--surface);">
        <Content />
      </article>
      <p>
        <a href="/blog/" class="mono-link hover-line">
          -> Back to blog
        </a>
      </p>
    </main>
  </body>
</html>

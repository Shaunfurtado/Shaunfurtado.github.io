---
import { CollectionEntry, getCollection } from 'astro:content';

type Props = {
  post: CollectionEntry<'blog'>;
};

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts
    .filter((post) => !post.data.draft)
    .map((post) => ({
      params: { slug: post.slug },
      props: { post },
    }));
}

const { post } = Astro.props as Props;
const { Content } = await post.render();

const formatDate = (value: Date) =>
  value.toLocaleDateString('en-GB', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{post.data.title} | Shaun Furtado</title>
    <meta name="description" content={post.data.description} />
    <meta property="og:title" content={post.data.title} />
    <meta property="og:description" content={post.data.description} />
    <meta
      property="article:published_time"
      content={post.data.pubDate.toISOString()}
    />
    <meta property="og:url" content={`https://shaunfurtado.is-a.dev/blog/${post.slug}/`} />
    <meta property="og:type" content="article" />
    <meta name="robots" content="index, follow" />

    <script src="https://cdn.tailwindcss.com"></script>
    <style>
      body {
        background-color: #030303;
        color: #e0e0e0;
        min-height: 100vh;
        margin: 0;
      }
      article h1,
      article h2,
      article h3,
      article h4 {
        color: #f2f2f2;
      }
    </style>
  </head>
  <body class="antialiased">
    <main class="max-w-4xl mx-auto px-6 py-16 space-y-6">
      <p class="text-xs font-mono uppercase tracking-widest text-zinc-400">
        {formatDate(post.data.pubDate)}
      </p>
      <h1 class="text-4xl md:text-5xl font-black tracking-tight leading-tight max-w-3xl">
        {post.data.title}
      </h1>
      <article class="prose prose-invert prose-zinc max-w-none">
        <Content />
      </article>
      <p>
        <a href="/blog/" class="text-sm font-mono uppercase tracking-widest text-zinc-400">
          -> Back to blog
        </a>
      </p>
    </main>
  </body>
</html>
